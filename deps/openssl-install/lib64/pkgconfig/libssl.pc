prefix=/home/work/nanoclaude-c/deps/openssl-install
exec_prefix=${prefix}
libdir=${exec_prefix}/lib64
includedir=${prefix}/include 

Name: OpenSSL-libssl
Description: Secure Sockets Layer and cryptography libraries
Version: 3.3.2
Requires.private: libcrypto
Libs: -L${libdir} -lssl
Cflags: -I${includedir}
